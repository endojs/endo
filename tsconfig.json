{
    "extends": "./tsconfig.eslint-base.json",
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
    },
    "exclude": [
        "api-docs",
        "api-docs/**",
        "**/node_modules",
        "packages/eslint-plugin",
        "packages/ses-integration-test",
        "packages/module-source",
        "packages/ocapn",
        "packages/ocapn-noise",
        "packages/test262-runner",
        "packages/ses/types.test-d.ts",
        "packages/chat",
        "packages/chat-network-view",
        "packages/conversation-tree",
        "packages/demo",
        "packages/fae",
        "packages/familiar",
        "packages/genie",
        "packages/hex-test",
        "packages/inventory-graph",
        "packages/ses-test",
        "packages/jaine",
        "packages/lal",
        "packages/platform",
        "packages/whylip",
        "**/build",
        "**/demo",
        "**/dist",
        "**/docs",
    ],
    "include": [
        "./**/*.ts",
        "packages/**/*.js"
    ],
}
