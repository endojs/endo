# LLM provider for Endo agents (lal, fae, jaine).
# Copy this to .env and fill in your values.
# The Vite dev server loads this automatically.

# Primary model — used for composition and tool execution
ENDO_LLM_HOST=https://api.anthropic.com
ENDO_LLM_MODEL=claude-sonnet-4-6-20250514
ENDO_LLM_AUTH_TOKEN=sk-ant-...

# Fast model (optional) — used for quick routing decisions.
# Defaults to primary host/auth if only model is set.
# ENDO_LLM_FAST_MODEL=claude-haiku-4-5-20251001
# ENDO_LLM_FAST_HOST=https://api.anthropic.com
# ENDO_LLM_FAST_AUTH_TOKEN=sk-ant-...
