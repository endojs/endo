# Endo OS: Minimal Linux kernel config for QEMU x86_64
#
# This kernel provides ONLY what V8 needs:
#   - Memory management (mmap, mprotect for JIT code pages)
#   - Threading (pthreads for V8 background tasks)
#   - virtio-blk (block storage for persistence)
#   - virtio-net (networking for WebSocket gateway)
#   - Serial console (ttyS0 for boot output)
#   - Initramfs support (our only "filesystem")
#
# Everything else is disabled: no shells, no coreutils, no
# process isolation, no ext4, no USB, no sound.

# Architecture
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4

# General
CONFIG_LOCALVERSION="-endo-os"
CONFIG_DEFAULT_HOSTNAME="endo"
CONFIG_POSIX_MQUEUE=n
CONFIG_AUDIT=n
CONFIG_BSD_PROCESS_ACCT=n
CONFIG_TASKSTATS=n

# Memory
CONFIG_MMU=y
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_MEMORY_HOTPLUG=n
CONFIG_COMPACTION=n
CONFIG_KSM=n

# Initramfs (this IS our root filesystem)
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_BZIP2=n
CONFIG_RD_LZMA=n
CONFIG_RD_XZ=n
CONFIG_RD_LZO=n
CONFIG_RD_LZ4=n
CONFIG_RD_ZSTD=n

# Console / Serial
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_TTY=y
CONFIG_VT=n
CONFIG_CONSOLE_TRANSLATIONS=n
CONFIG_FRAMEBUFFER_CONSOLE=n

# Block layer (for virtio-blk)
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# Virtio (QEMU paravirtualized devices)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=n
CONFIG_VIRTIO_BALLOON=n

# PCI (needed by virtio-pci)
CONFIG_PCI=y

# Networking (minimal TCP/IP for WebSocket gateway)
CONFIG_NET=y
CONFIG_INET=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_IPV6=n
CONFIG_NETFILTER=n
CONFIG_WIRELESS=n
CONFIG_RFKILL=n
CONFIG_BLUETOOTH=n

# Disable all real filesystems (we use initramfs only)
CONFIG_EXT4_FS=n
CONFIG_XFS_FS=n
CONFIG_BTRFS_FS=n
CONFIG_FAT_FS=n
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Disable everything we don't need
CONFIG_SOUND=n
CONFIG_USB_SUPPORT=n
CONFIG_INPUT=n
CONFIG_SERIO=n
CONFIG_HID=n
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_LOGO=n
CONFIG_SECURITY=n
CONFIG_CRYPTO_USER=n
CONFIG_MODULES=n
CONFIG_SWAP=n
CONFIG_SYSVIPC=n
CONFIG_FHANDLE=n
CONFIG_CGROUPS=n
CONFIG_NAMESPACES=n
CONFIG_PROFILING=n
CONFIG_FTRACE=n
CONFIG_DEBUG_KERNEL=n
CONFIG_PRINTK=y

# Executable format (for endo-init static binary)
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=n
CONFIG_BINFMT_MISC=n

# Timer and clock (needed by V8 for Date.now / setTimeout)
CONFIG_HIGH_RES_TIMERS=y
CONFIG_RTC_CLASS=n
CONFIG_POSIX_TIMERS=y

# Random number generation (for crypto)
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# Power management (minimal — just reboot/shutdown)
CONFIG_ACPI=y
CONFIG_PM=n

# Disable all other drivers
CONFIG_WLAN=n
CONFIG_ATA=n
CONFIG_SCSI=n
CONFIG_MD=n
CONFIG_WATCHDOG=n
CONFIG_HWMON=n
CONFIG_THERMAL=n
CONFIG_MFD_CORE=n
CONFIG_REGULATOR=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_LEDS_CLASS=n
CONFIG_EDAC=n
CONFIG_RAS=n
CONFIG_ACCESSIBILITY=n
CONFIG_INFINIBAND=n
CONFIG_STAGING=n
