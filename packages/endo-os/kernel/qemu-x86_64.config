# Endo OS: Minimal Linux kernel config for QEMU x86_64
#
# This kernel provides what the Endo OS device capabilities need:
#   - Memory management (mmap, mprotect for V8 JIT code pages)
#   - Threading (pthreads for V8 background tasks)
#   - virtio-blk (block storage for persistence)
#   - virtio-net (networking for WebSocket gateway)
#   - Serial console (ttyS0 for boot output)
#   - Framebuffer (display output for chat shell)
#   - V4L2 / USB camera support
#   - ALSA / OSS audio capture (microphone)
#   - USB host controller (for camera + audio devices)
#   - Initramfs support (our only "filesystem")
#
# No shells, no coreutils, no process isolation, no ext4.

# Architecture
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4

# General
CONFIG_LOCALVERSION="-endo-os"
CONFIG_DEFAULT_HOSTNAME="endo"
CONFIG_POSIX_MQUEUE=n
CONFIG_AUDIT=n
CONFIG_BSD_PROCESS_ACCT=n
CONFIG_TASKSTATS=n

# Memory
CONFIG_MMU=y
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_MEMORY_HOTPLUG=n
CONFIG_COMPACTION=n
CONFIG_KSM=n

# Initramfs (this IS our root filesystem)
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_BZIP2=n
CONFIG_RD_LZMA=n
CONFIG_RD_XZ=n
CONFIG_RD_LZO=n
CONFIG_RD_LZ4=n
CONFIG_RD_ZSTD=n

# Console / Serial
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_CONSOLE_TRANSLATIONS=y

# Block layer (for virtio-blk)
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# Virtio (QEMU paravirtualized devices)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=n
CONFIG_VIRTIO_BALLOON=n

# PCI (needed by virtio-pci)
CONFIG_PCI=y

# Networking (minimal TCP/IP for WebSocket gateway)
CONFIG_NET=y
CONFIG_INET=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_IPV6=n
CONFIG_NETFILTER=n
CONFIG_WIRELESS=n
CONFIG_RFKILL=n
CONFIG_BLUETOOTH=n

# Disable all real filesystems (we use initramfs only)
CONFIG_EXT4_FS=n
CONFIG_XFS_FS=n
CONFIG_BTRFS_FS=n
CONFIG_FAT_FS=n
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Framebuffer (display capability)
CONFIG_FB=y
CONFIG_FB_VESA=y
CONFIG_FB_EFI=y
CONFIG_FB_SIMPLE=y
CONFIG_DRM=y
CONFIG_DRM_BOCHS=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_LOGO=n

# USB host (for camera and audio devices)
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y

# Input (keyboard for chat shell, USB HID)
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_EVDEV=y
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y

# Camera (V4L2 + USB Video Class)
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_USB_SUPPORT=y
CONFIG_VIDEO_DEV=y
CONFIG_VIDEO_V4L2=y
CONFIG_USB_VIDEO_CLASS=y
CONFIG_MEDIA_CAMERA_SUPPORT=y

# Audio capture (ALSA + OSS compat for microphone)
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_PCM=y
CONFIG_SND_USB_AUDIO=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_GENERIC=y
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_OSSEMUL=y
CONFIG_SND_PCM_OSS=y
CONFIG_SND_MIXER_OSS=y
# QEMU audio: Intel HDA or AC97
CONFIG_SND_AC97_CODEC=y
CONFIG_SND_INTEL8X0=y

# Virtio GPU + sound (QEMU paravirtualized)
CONFIG_VIRTIO_SND=y

# Remaining disabled subsystems
CONFIG_SECURITY=n
CONFIG_CRYPTO_USER=n
CONFIG_MODULES=n
CONFIG_SWAP=n
CONFIG_SYSVIPC=n
CONFIG_FHANDLE=n
CONFIG_CGROUPS=n
CONFIG_NAMESPACES=n
CONFIG_PROFILING=n
CONFIG_FTRACE=n
CONFIG_DEBUG_KERNEL=n
CONFIG_PRINTK=y

# Executable format (for endo-init static binary)
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=n
CONFIG_BINFMT_MISC=n

# Timer and clock (needed by V8 for Date.now / setTimeout)
CONFIG_HIGH_RES_TIMERS=y
CONFIG_RTC_CLASS=n
CONFIG_POSIX_TIMERS=y

# Random number generation (for crypto)
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# Power management (minimal — just reboot/shutdown)
CONFIG_ACPI=y
CONFIG_PM=n

# Disable all other drivers
CONFIG_WLAN=n
CONFIG_ATA=n
CONFIG_SCSI=n
CONFIG_MD=n
CONFIG_WATCHDOG=n
CONFIG_HWMON=n
CONFIG_THERMAL=n
CONFIG_MFD_CORE=n
CONFIG_REGULATOR=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_LEDS_CLASS=n
CONFIG_EDAC=n
CONFIG_RAS=n
CONFIG_ACCESSIBILITY=n
CONFIG_INFINIBAND=n
CONFIG_STAGING=n
