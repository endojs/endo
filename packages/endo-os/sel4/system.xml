<?xml version="1.0" encoding="UTF-8"?>
<!--
  Endo OS: seL4 Microkit System Description (x86_64)
-->
<system>
    <protection_domain
        name="endo_init"
        priority="254"
        stack_size="0x100000">
        <program_image path="endo-init.elf" />

        <!-- JS heap: 32 MB for QuickJS + daemon. -->
        <map
            mr="js_heap"
            vaddr="0x10000000"
            perms="rw"
            setvar_vaddr="js_heap_vaddr" />
    </protection_domain>

    <memory_region name="js_heap" size="0x2000000" />
</system>
