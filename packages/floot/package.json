    "url": "https://github.com/endojs/endo/issues"
  },
  "type": "module",
  "exports": {
    ".": "./agent.js",
    "./driver.js": "./driver.js",
    "./src/stream.js": "./src/stream.js",
    "./providers/index.js": "./providers/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
