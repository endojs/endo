    "@endo/exo": "workspace:^",
    "@endo/far": "workspace:^",
    "@endo/init": "workspace:^",
    "@endo/lal": "workspace:^",
    "@endo/marshal": "workspace:^",
    "@endo/pass-style": "workspace:^",
    "@endo/patterns": "workspace:^",
    "@endo/promise-kit": "workspace:^"
  },
  "devDependencies": {
    "@endo/cli": "workspace:^",
    "ava": "catalog:dev",
    "c8": "catalog:dev",
