{
  "name": "@endo/bundle-source",
  "version": "4.3.1",
  "description": "Create source bundles from ES Modules",
  "type": "module",
  "main": "src/index.js",
  "bin": "./src/tool.js",
  "exports": {
    ".": "./src/index.js",
    "./exported.js": "./src/exports.js",
    "./cache.js": "./cache.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "exit 0",
    "test": "ava",
    "trace:merge": "node tools/trace-merge.js",
    "test:xs": "exit 0",
    "lint-fix": "eslint --fix '**/*.js'",
    "lint": "yarn lint:types && yarn lint:eslint",
    "lint:eslint": "eslint .",
    "lint:types": "tsc"
  },
  "dependencies": {
    "@endo/base64": "workspace:^",
    "@endo/compartment-mapper": "workspace:^",
    "@endo/evasive-transform": "workspace:^",
    "@endo/harden": "workspace:^",
    "@endo/init": "workspace:^",
    "@endo/promise-kit": "workspace:^",
    "@endo/where": "workspace:^",
    "amaro": "^1.1.9"
  },
  "devDependencies": {
    "@endo/lockdown": "workspace:^",
    "@endo/ses-ava": "workspace:^",
    "@endo/zip": "workspace:^",
    "ava": "catalog:dev",
    "c8": "catalog:dev",
    "eslint": "catalog:dev",
    "ses": "workspace:^",
    "typescript": "catalog:dev"
  },
  "keywords": [],
  "files": [
    "./*.d.ts",
    "./*.js",
    "./*.map",
    "LICENSE*",
    "SECURITY*",
    "dist",
    "lib",
    "src",
    "tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/endojs/endo.git",
    "directory": "packages/bundle-source"
  },
  "author": "Endo contributors",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/endojs/endo/issues"
  },
  "homepage": "https://github.com/endojs/endo#readme",
  "publishConfig": {
    "access": "public"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ]
  },
  "eslintConfig": {
    "extends": [
      "plugin:@endo/internal"
    ],
    "ignorePatterns": [
      "dist/",
      "scripts/",
      "demo/"
    ]
  },
  "typeCoverage": {
    "atLeast": 69.54
  }
}
