{
  "name": "@endo/hex-test",
  "version": "1.0.0",
  "private": true,
  "description": "Tests for @endo/hex (sink-only package to break devDependency cycles).",
  "keywords": [],
  "author": "Endo contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/endojs/endo/tree/master/packages/hex-test#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/endojs/endo.git",
    "directory": "packages/hex-test"
  },
  "bugs": {
    "url": "https://github.com/endojs/endo/issues"
  },
  "type": "module",
  "exports": {},
  "scripts": {
    "build": "exit 0",
    "lint": "yarn lint:types && yarn lint:eslint",
    "lint-fix": "eslint --fix .",
    "lint:eslint": "eslint .",
    "lint:types": "tsc",
    "test": "ava"
  },
  "dependencies": {
    "@endo/hex": "workspace:^",
    "@endo/ses-ava": "workspace:^",
    "ses": "workspace:^"
  },
  "devDependencies": {
    "ava": "catalog:dev",
    "eslint": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "ava": {
    "files": [
      "test/**/*.test.js"
    ],
    "nodeArguments": [
      "--conditions=test-endo-hex"
    ],
    "timeout": "60s"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "eslintConfig": {
    "extends": [
      "plugin:@endo/internal"
    ],
    "settings": {
      "import/resolver": {
        "exports": {
          "conditions": ["test-endo-hex"]
        },
        "node": {}
      }
    }
  }
}
