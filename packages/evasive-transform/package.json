{
  "name": "@endo/evasive-transform",
  "version": "2.3.0",
  "description": "Source transforms to evade SES censorship",
  "keywords": [
    "ses",
    "transform"
  ],
  "author": "Endo contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/endojs/endo/tree/master/packages/evasive-transform#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/endojs/endo.git",
    "directory": "packages/evasive-transform"
  },
  "bugs": {
    "url": "https://github.com/endojs/endo/issues"
  },
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "exports": {
    ".": "./index.js",
    "./visitor.js": "./visitor.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "ava",
    "test:c8": "c8 ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0",
    "build": "exit 0",
    "lint-fix": "yarn lint:eslint --fix && yarn lint:types",
    "lint": "yarn lint:types && yarn lint:eslint",
    "lint:types": "tsc",
    "lint:eslint": "eslint .",
    "test:rebuild-fixtures": "node test/rebuild-fixtures.js"
  },
  "devDependencies": {
    "@babel/types": "~7.28.2",
    "@endo/ses-ava": "workspace:^",
    "@types/babel__generator": "~7.27.0"
  },
  "files": [
    "./*.d.ts",
    "./*.js",
    "./*.map",
    "LICENSE*",
    "SECURITY*",
    "dist",
    "lib",
    "src",
    "tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "timeout": "2m"
  },
  "dependencies": {
    "@babel/generator": "^7.28.3",
    "@babel/parser": "~7.28.3",
    "@babel/traverse": "~7.28.3",
    "@types/babel__traverse": "~7.28.0"
  }
}
