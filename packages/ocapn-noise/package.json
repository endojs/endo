{
  "name": "@endo/ocapn-noise",
  "version": "0.1.0",
  "private": true,
  "description": "A Noise Protocol netlayer for @endo/ocapn.",
  "keywords": [],
  "author": "Endo contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/endojs/endo/tree/master/packages/ocapn-noise#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/endojs/endo.git",
    "directory": "packages/ocapn-noise"
  },
  "bugs": {
    "url": "https://github.com/endojs/endo/issues"
  },
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "exit 0",
    "lint": "yarn lint:types && yarn lint:eslint",
    "lint-fix": "yarn lint:eslint --fix && yarn lint:types",
    "lint:eslint": "eslint .",
    "lint:types": "tsc",
    "test": "ava",
    "test:c8": "c8 ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0"
  },
  "devDependencies": {
    "@endo/lockdown": "workspace:^",
    "@endo/ses-ava": "workspace:^"
  },
  "files": [
    "./*.d.ts",
    "./*.js",
    "./*.map",
    "LICENSE*",
    "SECURITY*",
    "dist",
    "lib",
    "src",
    "tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "timeout": "2m"
  }
}
