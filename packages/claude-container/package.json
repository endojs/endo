{
  "name": "@endo/claude-container",
  "version": "0.0.0",
  "private": true,
  "description": "Claude Code microVM sandboxes as Endo capabilities — factory caplet, ClaudeClient exo, and 9P bridge for projecting an Endo filesystem capability into a sandbox workspace.",
  "keywords": [],
  "author": "Endo contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/endojs/endo.git",
    "directory": "packages/claude-container"
  },
  "bugs": {
    "url": "https://github.com/endojs/endo/issues"
  },
  "type": "module",
  "exports": {
    ".": "./src/claude-container-factory.js",
    "./setup.js": "./setup.js",
    "./src/claude-client.js": "./src/claude-client.js",
    "./src/orchestrator-client.js": "./src/orchestrator-client.js",
    "./src/fs-bridge-9p.js": "./src/fs-bridge-9p.js",
    "./src/claude-credentials-factory.js": "./src/claude-credentials-factory.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "exit 0",
    "test": "ava",
    "setup": "endo run --UNCONFINED setup.js --powers @agent -E FACTORY_NAME=${FACTORY_NAME:-claude-container-factory} -E ORCHESTRATOR_SOCKET=${ORCHESTRATOR_SOCKET:-/run/claude-orch/api.sock}",
    "create-factory": "./scripts/create-factory.sh",
    "lint": "yarn lint:eslint",
    "lint-fix": "yarn lint:eslint --fix",
    "lint:eslint": "eslint '**/*.js'"
  },
  "ava": {
    "files": [
      "test/**/*.test.js"
    ],
    "timeout": "60s"
  },
  "dependencies": {
    "@endo/claude-orch": "workspace:^",
    "@endo/daemon": "workspace:^",
    "@endo/errors": "workspace:^",
    "@endo/eventual-send": "workspace:^",
    "@endo/exo": "workspace:^",
    "@endo/exo-stream": "workspace:^",
    "@endo/far": "workspace:^",
    "@endo/init": "workspace:^",
    "@endo/patterns": "workspace:^",
    "@endo/promise-kit": "workspace:^",
    "@endo/remote-fs": "workspace:^"
  },
  "devDependencies": {
    "@endo/cli": "workspace:^",
    "ava": "catalog:dev",
    "eslint": "catalog:dev"
  },
  "eslintConfig": {
    "extends": [
      "plugin:@endo/internal"
    ]
  }
}
