{
  "name": "imports-edge-cases-lib",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": "./src/main.js",
    "./mismatched-export/*": "./src/mismatched-export"
  },
  "imports": {
    "#helper": "./src/helper.js",
    "#excluded": null,
    "#secret/*.js": null,
    "#cond": { "development": "./src/cond-dev.js", "default": "./src/cond-default.js" },
    "#cond-null": { "development": null },
    "#mismatched/*": "./src/mismatched",
    "invalid-key": "./src/invalid.js",
    "#bad-value": 42
  },
  "scripts": {
    "preinstall": "echo DO NOT INSTALL TEST FIXTURES; exit -1"
  }
}
