{
  "name": "@endo/endo-fs",
  "version": "0.0.0",
  "private": true,
  "description": "Pipelinable, stream-friendly filesystem capabilities for Endo — designed so a deeply-nested walk + open + range read costs one CapTP round trip rather than depth-plus-two.",
  "keywords": [],
  "author": "Endo contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/endojs/endo.git",
    "directory": "packages/endo-fs"
  },
  "bugs": {
    "url": "https://github.com/endojs/endo/issues"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./src/type-guards.js": "./src/type-guards.js",
    "./src/in-memory.js": "./src/in-memory.js",
    "./src/in-memory-module.js": "./src/in-memory-module.js",
    "./src/cas.js": "./src/cas.js",
    "./src/cached-fs.js": "./src/cached-fs.js",
    "./src/node-fs.js": "./src/node-fs.js",
    "./src/node-fs-module.js": "./src/node-fs-module.js",
    "./src/readonly.js": "./src/readonly.js",
    "./src/from-mount.js": "./src/from-mount.js",
    "./src/compose.js": "./src/compose.js",
    "./src/layer.js": "./src/layer.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "exit 0",
    "test": "ava",
    "lint": "yarn lint:eslint",
    "lint-fix": "yarn lint:eslint --fix",
    "lint:eslint": "eslint '**/*.js'",
    "attach": "endo run --UNCONFINED attach.js --powers @agent -E ENDO_FS_ROOT=${ENDO_FS_ROOT:-} -E ENDO_FS_NAME=${ENDO_FS_NAME:-} -E ENDO_FS_READ_ONLY=${ENDO_FS_READ_ONLY:-}",
    "mkmem": "endo run --UNCONFINED mkmem.js --powers @agent -E ENDO_FS_NAME=${ENDO_FS_NAME:-}"
  },
  "dependencies": {
    "@endo/errors": "workspace:^",
    "@endo/eventual-send": "workspace:^",
    "@endo/exo": "workspace:^",
    "@endo/exo-stream": "workspace:^",
    "@endo/far": "workspace:^",
    "@endo/init": "workspace:^",
    "@endo/patterns": "workspace:^",
    "@endo/stream": "workspace:^"
  },
  "devDependencies": {
    "@endo/captp": "workspace:^",
    "ava": "catalog:dev",
    "eslint": "catalog:dev"
  },
  "ava": {
    "files": [
      "test/**/*.test.js"
    ],
    "timeout": "60s"
  },
  "eslintConfig": {
    "extends": [
      "plugin:@endo/internal"
    ]
  }
}
